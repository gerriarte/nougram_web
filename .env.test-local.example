# ============================================
# Variables para PRUEBAS LOCALES (stack producción)
# ============================================
# Uso: cp .env.test-local.example .env.test-local
#      docker compose -f docker-compose.prod.yml --env-file .env.test-local up -d
#
# Acceder a http://localhost
# ============================================

POSTGRES_USER=postgres
POSTGRES_PASSWORD=testlocal123
POSTGRES_DB=nougram_db
DATABASE_URL=postgresql+asyncpg://postgres:testlocal123@postgres:5432/nougram_db

SECRET_KEY=test-secret-key-min-32-chars-for-jwt

# Localhost para pruebas
CORS_ORIGINS=http://localhost,http://localhost:3000,http://127.0.0.1
FRONTEND_URL=http://localhost
NEXT_PUBLIC_API_URL=http://localhost/api/v1

HTTP_PORT=80

# Vacíos para pruebas (OAuth, AI, etc.)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_SERVICE_ACCOUNT_PATH=
GOOGLE_SHEETS_ID=
OPENAI_API_KEY=
GOOGLE_AI_API_KEY=
