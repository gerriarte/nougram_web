# ============================================
# Variables de Entorno para PRODUCCIÓN
# ============================================
# ⚠️ IMPORTANTE: 
# - Renombrar este archivo a .env.production
# - NO commitear el archivo .env.production al repositorio
# - Usar un gestor de secretos (AWS Secrets Manager, HashiCorp Vault, etc.)
# ============================================

# ============================================
# BASE DE DATOS (OBLIGATORIO)
# ============================================
DATABASE_URL=postgresql+asyncpg://usuario:password@host:5432/nougram_db

# ============================================
# SEGURIDAD JWT (OBLIGATORIO)
# ============================================
# Generar con: python scripts/generate_secret_key.py
SECRET_KEY=tu-clave-secreta-generada-aqui
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# ============================================
# GOOGLE OAUTH (OBLIGATORIO si se usa OAuth)
# ============================================
GOOGLE_CLIENT_ID=tu-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=tu-google-client-secret
GOOGLE_SERVICE_ACCOUNT_PATH=/app/config/google-service-account.json

# ============================================
# GOOGLE SHEETS (OBLIGATORIO si se usa Sheets)
# ============================================
GOOGLE_SHEETS_ID=tu-google-sheets-id

# ============================================
# AMBIENTE (OBLIGATORIO)
# ============================================
ENVIRONMENT=production

# ============================================
# CORS (CRÍTICO - Configurar dominios exactos)
# ============================================
CORS_ORIGINS=https://app.nougram.com,https://www.nougram.com

# ============================================
# FRONTEND URL (OBLIGATORIO)
# ============================================
FRONTEND_URL=https://app.nougram.com

# ============================================
# EMAIL SMTP (Opcional pero recomendado)
# ============================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=noreply@nougram.com
SMTP_PASSWORD=tu-app-password
SMTP_FROM_EMAIL=noreply@nougram.com
SMTP_FROM_NAME=Nougram
SMTP_USE_TLS=true

# ============================================
# IA (Opcional)
# ============================================
OPENAI_API_KEY=
GOOGLE_AI_API_KEY=

# ============================================
# STRIPE (Opcional - Solo si se usa billing)
# ============================================
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_IDS={}

# ============================================
# EXCHANGE RATES (Opcional)
# ============================================
EXCHANGE_RATE_API_KEY=
EXCHANGE_RATE_API_URL=https://api.exchangerate-api.com/v4/latest

# ============================================
# REDIS / CELERY (Opcional pero recomendado)
# ============================================
CELERY_BROKER_URL=redis://redis-host:6379/0
CELERY_RESULT_BACKEND=redis://redis-host:6379/0

# ============================================
# PUBLIC QUOTE URL (Opcional)
# ============================================
PUBLIC_QUOTE_BASE_URL=https://app.nougram.com

# ============================================
# FEATURE FLAGS (Opcional)
# ============================================
FEATURE_ROLES=false
FEATURE_ROLES_ENFORCE=false
