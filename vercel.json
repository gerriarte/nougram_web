{
    "buildCommand": "npm run build",
    "outputDirectory": "dist",
    "framework": "vite",
    "functions": {
        "api/blog-seo.ts": {
            "includeFiles": "dist/index.html"
        }
    },
    "rewrites": [
        {
            "source": "/blog/:slug",
            "destination": "/api/blog-seo?slug=:slug"
        },
        {
            "source": "/((?!api/).*)",
            "destination": "/index.html"
        }
    ]
}