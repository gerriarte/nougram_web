"use client"

import { useGetTeamMembers } from "@/lib/queries"
import { Card, CardContent, CardDescription, CardHeader, CardTitle } from "@/components/ui/card"
import { formatCurrency } from "@/lib/currency"
import { Loader2, Users } from "lucide-react"
import { Badge } from "@/components/ui/badge"

export function TeamCostSummary() {
  const { data, isLoading, error } = useGetTeamMembers()

  if (isLoading) {
    return (
      <Card>
        <CardHeader>
          <CardTitle>Costo del Equipo</CardTitle>
          <CardDescription>Resumen de costos mensuales</CardDescription>
        </CardHeader>
        <CardContent>
          <div className="flex items-center justify-center py-8">
            <Loader2 className="h-6 w-6 animate-spin text-muted-foreground" />
          </div>
        </CardContent>
      </Card>
    )
  }

  if (error) {
    return (
      <Card>
        <CardHeader>
          <CardTitle>Costo del Equipo</CardTitle>
          <CardDescription>Resumen de costos mensuales</CardDescription>
        </CardHeader>
        <CardContent>
          <p className="text-sm text-destructive">Error al cargar datos</p>
        </CardContent>
      </Card>
    )
  }

  const members = data?.items || []
  const activeMembers = members.filter(m => m.is_active)

  // Group salaries by currency
  const salariesByCurrency = activeMembers.reduce((acc, member) => {
    const currency = member.currency || "USD"
    if (!acc[currency]) {
      acc[currency] = 0
    }
    acc[currency] += member.salary_monthly_brute
    return acc
  }, {} as Record<string, number>)

  // Calculate total billable hours per month
  // Adjust for non-billable hours percentage (Sprint 14)
  const totalHours = activeMembers.reduce(
    (sum, member) => {
      const nonBillablePct = (member.non_billable_hours_percentage || 0) / 100.0
      return sum + member.billable_hours_per_week * 4.33 * (1 - nonBillablePct)
    },
    0
  )

  // Get primary currency (most used) or first one
  const primaryCurrency = Object.keys(salariesByCurrency).length > 0
    ? Object.keys(salariesByCurrency).reduce((a, b) =>
        salariesByCurrency[a] > salariesByCurrency[b] ? a : b
      )
    : "USD"

  const hasMultipleCurrencies = Object.keys(salariesByCurrency).length > 1

  return (
    <Card>
      <CardHeader>
        <div className="flex items-center justify-between">
          <div>
            <CardTitle className="text-lg">Resumen del Equipo</CardTitle>
            <CardDescription>Costo total mensual</CardDescription>
          </div>
          <Users className="h-5 w-5 text-muted-foreground" />
        </div>
      </CardHeader>
      <CardContent>
        <div className="space-y-6">
          {/* Total Cost */}
          <div>
            {hasMultipleCurrencies ? (
              <div className="space-y-2">
                <p className="text-sm text-muted-foreground mb-2">Total Mensual por Moneda</p>
                {Object.entries(salariesByCurrency).map(([currency, amount]) => (
                  <div key={currency} className="flex justify-between items-center">
                    <div className="flex items-center gap-2">
                      <Badge variant="outline" className="font-mono">
                        {currency}
                      </Badge>
                    </div>
                    <p className="text-lg font-semibold">
                      {formatCurrency(amount, currency)}
                    </p>
                  </div>
                ))}
              </div>
            ) : (
              <div>
                <p className="text-sm text-muted-foreground mb-1">Total Mensual</p>
                <div className="text-3xl font-bold">
                  {formatCurrency(salariesByCurrency[primaryCurrency] || 0, primaryCurrency)}
                </div>
              </div>
            )}
          </div>

          {/* Stats Grid */}
          <div className="grid grid-cols-1 gap-4 pt-4 border-t">
            <div className="flex justify-between items-center">
              <p className="text-sm text-muted-foreground">Miembros Activos</p>
              <p className="text-lg font-semibold">{activeMembers.length}</p>
            </div>
            <div className="flex justify-between items-center">
              <p className="text-sm text-muted-foreground">Horas Mensuales</p>
              <p className="text-lg font-semibold">{totalHours.toFixed(1)}h</p>
            </div>
            {hasMultipleCurrencies && (
              <div className="pt-2 border-t">
                <p className="text-xs text-muted-foreground mb-2">Monedas utilizadas</p>
                <div className="flex flex-wrap gap-2">
                  {Object.keys(salariesByCurrency).map((currency) => (
                    <Badge key={currency} variant="outline" className="font-mono text-xs">
                      {currency}
                    </Badge>
                  ))}
                </div>
              </div>
            )}
          </div>
        </div>
      </CardContent>
    </Card>
  )
}

