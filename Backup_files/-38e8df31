"use client"

import { useGetBlendedCostRate } from "@/lib/queries"
import { Card, CardContent, CardDescription, CardHeader, CardTitle } from "@/components/ui/card"
import { formatCurrency } from "@/lib/currency"
import { Loader2, Users, DollarSign, Receipt, TrendingUp, Coins } from "lucide-react"
import { useGetCurrencySettings } from "@/lib/queries"
import { TeamCostSummary } from "@/components/team/team-cost-summary"
import { FixedCostsSummary } from "@/components/costs/fixed-costs-summary"
import { TaxesSummary } from "@/components/taxes/taxes-summary"
import { BlendedCostRate } from "@/components/costs/blended-cost-rate"

export function BusinessSummaryDashboard() {
  const { data, isLoading, error } = useGetBlendedCostRate()
  const { data: currencySettings } = useGetCurrencySettings()
  const primaryCurrency = data?.primary_currency || currencySettings?.primary_currency || "USD"

  if (isLoading) {
    return (
      <div className="space-y-6">
        <div className="flex items-center justify-center py-12">
          <Loader2 className="h-8 w-8 animate-spin text-muted-foreground" />
        </div>
      </div>
    )
  }

  if (error) {
    return (
      <Card>
        <CardHeader>
          <CardTitle>Resumen del Negocio</CardTitle>
          <CardDescription>Dashboard de costos por área</CardDescription>
        </CardHeader>
        <CardContent>
          <p className="text-sm text-destructive">Error al cargar datos</p>
        </CardContent>
      </Card>
    )
  }

  const totalCosts = data?.total_monthly_costs || 0
  const totalHours = data?.total_monthly_hours || 0
  const activeMembers = data?.active_team_members || 0

  return (
    <div className="space-y-6">
      {/* Header */}
      <div>
        <h1 className="text-3xl font-bold text-grey-900">Resumen del Negocio</h1>
        <p className="text-grey-600 mt-1">Dashboard de costos por área de tu organización</p>
      </div>

      {/* Total Monthly Costs - Highlighted */}
      <Card className="border-primary-200 bg-gradient-to-br from-primary-50 to-white">
        <CardHeader>
          <div className="flex items-center justify-between">
            <div>
              <CardTitle className="text-xl font-semibold text-grey-900">
                Costos Mensuales Totales
              </CardTitle>
              <CardDescription className="text-grey-600 mt-1">
                Suma de todos los costos operativos mensuales
              </CardDescription>
            </div>
            <div className="p-3 bg-primary-100 rounded-lg">
              <DollarSign className="h-6 w-6 text-primary-600" />
            </div>
          </div>
        </CardHeader>
        <CardContent>
          <div className="space-y-6">
            {/* Total Cost */}
            <div>
              <p className="text-sm text-muted-foreground mb-2">Total Mensual</p>
              <div className="text-4xl font-bold text-grey-900">
                {formatCurrency(totalCosts, primaryCurrency)}
              </div>
              <p className="text-xs text-muted-foreground mt-1">por mes</p>
            </div>

            {/* Stats Grid */}
            <div className="grid grid-cols-3 gap-4 pt-4 border-t border-grey-200">
              <div>
                <p className="text-xs text-muted-foreground mb-1">Miembros Activos</p>
                <p className="text-lg font-semibold text-grey-900">{activeMembers}</p>
              </div>
              <div>
                <p className="text-xs text-muted-foreground mb-1">Horas Mensuales</p>
                <p className="text-lg font-semibold text-grey-900">{totalHours.toFixed(1)}h</p>
              </div>
              <div>
                <p className="text-xs text-muted-foreground mb-1">Moneda Principal</p>
                <p className="text-lg font-semibold text-grey-900">{primaryCurrency}</p>
              </div>
            </div>

            {/* Info */}
            <div className="pt-2 border-t border-grey-200">
              <div className="flex items-start gap-2 text-xs text-muted-foreground">
                <TrendingUp className="h-4 w-4 mt-0.5 flex-shrink-0" />
                <p>
                  Incluye salarios del equipo y costos fijos mensuales. 
                  Los costos se normalizan a la moneda primaria.
                </p>
              </div>
            </div>
          </div>
        </CardContent>
      </Card>

      {/* Cost Areas Grid */}
      <div className="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
        {/* Team Costs */}
        <div className="md:col-span-1">
          <TeamCostSummary />
        </div>

        {/* Fixed Costs */}
        <div className="md:col-span-1">
          <FixedCostsSummary />
        </div>

        {/* Taxes */}
        <div className="md:col-span-1">
          <TaxesSummary />
        </div>
      </div>

      {/* Blended Cost Rate - Full Width */}
      <div className="grid gap-6 md:grid-cols-1">
        <BlendedCostRate />
      </div>
    </div>
  )
}


