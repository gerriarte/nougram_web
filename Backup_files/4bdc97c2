"use client"

import { useGetTaxes } from "@/lib/queries"
import { Card, CardContent, CardDescription, CardHeader, CardTitle } from "@/components/ui/card"
import { Loader2, Receipt } from "lucide-react"
import { Badge } from "@/components/ui/badge"

export function TaxesSummary() {
  const { data, isLoading, error } = useGetTaxes(undefined, false)

  if (isLoading) {
    return (
      <Card>
        <CardHeader>
          <CardTitle>Resumen de Impuestos</CardTitle>
          <CardDescription>Configuración de impuestos</CardDescription>
        </CardHeader>
        <CardContent>
          <div className="flex items-center justify-center py-8">
            <Loader2 className="h-6 w-6 animate-spin text-muted-foreground" />
          </div>
        </CardContent>
      </Card>
    )
  }

  if (error) {
    return (
      <Card>
        <CardHeader>
          <CardTitle>Resumen de Impuestos</CardTitle>
          <CardDescription>Configuración de impuestos</CardDescription>
        </CardHeader>
        <CardContent>
          <p className="text-sm text-destructive">Error al cargar datos</p>
        </CardContent>
      </Card>
    )
  }

  const taxes = data?.items || []
  const activeTaxes = taxes.filter(t => t.is_active)
  const inactiveTaxes = taxes.length - activeTaxes.length

  // Calculate average tax rate
  const avgTaxRate = activeTaxes.length > 0
    ? activeTaxes.reduce((sum, tax) => sum + tax.percentage, 0) / activeTaxes.length
    : 0

  return (
    <Card>
      <CardHeader>
        <div className="flex items-center justify-between">
          <div>
            <CardTitle className="text-lg">Resumen de Impuestos</CardTitle>
            <CardDescription>Configuración de impuestos</CardDescription>
          </div>
          <Receipt className="h-5 w-5 text-muted-foreground" />
        </div>
      </CardHeader>
      <CardContent>
        <div className="space-y-4">
          {/* Stats */}
          <div className="space-y-3">
            <div className="flex justify-between items-center">
              <p className="text-sm text-muted-foreground">Total de Impuestos</p>
              <p className="text-lg font-semibold">{taxes.length}</p>
            </div>
            <div className="flex justify-between items-center">
              <p className="text-sm text-muted-foreground">Impuestos Activos</p>
              <Badge variant="default" className="bg-green-600">
                {activeTaxes.length}
              </Badge>
            </div>
            {inactiveTaxes > 0 && (
              <div className="flex justify-between items-center">
                <p className="text-sm text-muted-foreground">Impuestos Inactivos</p>
                <Badge variant="secondary">{inactiveTaxes}</Badge>
              </div>
            )}
          </div>

          {/* Average Rate */}
          {activeTaxes.length > 0 && (
            <div className="pt-4 border-t">
              <p className="text-sm text-muted-foreground mb-1">Tasa Promedio</p>
              <div className="text-2xl font-bold">
                {avgTaxRate.toFixed(2)}%
              </div>
              <p className="text-xs text-muted-foreground mt-1">
                Promedio de todos los impuestos activos
              </p>
            </div>
          )}
        </div>
      </CardContent>
    </Card>
  )
}


