"use client"

import { useGetFixedCosts } from "@/lib/queries"
import { Card, CardContent, CardDescription, CardHeader, CardTitle } from "@/components/ui/card"
import { formatCurrency } from "@/lib/currency"
import { Loader2, DollarSign } from "lucide-react"
import { Badge } from "@/components/ui/badge"

export function FixedCostsSummary() {
  const { data, isLoading, error } = useGetFixedCosts()

  if (isLoading) {
    return (
      <Card>
        <CardHeader>
          <CardTitle>Resumen de Costos Fijos</CardTitle>
          <CardDescription>Costo total mensual</CardDescription>
        </CardHeader>
        <CardContent>
          <div className="flex items-center justify-center py-8">
            <Loader2 className="h-6 w-6 animate-spin text-muted-foreground" />
          </div>
        </CardContent>
      </Card>
    )
  }

  if (error) {
    return (
      <Card>
        <CardHeader>
          <CardTitle>Resumen de Costos Fijos</CardTitle>
          <CardDescription>Costo total mensual</CardDescription>
        </CardHeader>
        <CardContent>
          <p className="text-sm text-destructive">Error al cargar datos</p>
        </CardContent>
      </Card>
    )
  }

  const costs = data?.items || []
  // Costs from API are already filtered (non-deleted)

  // Group costs by currency
  const costsByCurrency = costs.reduce((acc, cost) => {
    const currency = cost.currency || "USD"
    if (!acc[currency]) {
      acc[currency] = 0
    }
    acc[currency] += cost.amount_monthly
    return acc
  }, {} as Record<string, number>)

  // Get primary currency (most used) or first one
  const primaryCurrency = Object.keys(costsByCurrency).length > 0
    ? Object.keys(costsByCurrency).reduce((a, b) =>
        costsByCurrency[a] > costsByCurrency[b] ? a : b
      )
    : "USD"

  const hasMultipleCurrencies = Object.keys(costsByCurrency).length > 1
  const totalCosts = costs.length

  return (
    <Card>
      <CardHeader>
        <div className="flex items-center justify-between">
          <div>
            <CardTitle className="text-lg">Resumen de Costos Fijos</CardTitle>
            <CardDescription>Costo total mensual</CardDescription>
          </div>
          <DollarSign className="h-5 w-5 text-muted-foreground" />
        </div>
      </CardHeader>
      <CardContent>
        <div className="space-y-4">
          {/* Total Cost */}
          <div>
            {hasMultipleCurrencies ? (
              <div className="space-y-2">
                <p className="text-sm text-muted-foreground mb-2">Total Mensual por Moneda</p>
                {Object.entries(costsByCurrency).map(([currency, amount]) => (
                  <div key={currency} className="flex justify-between items-center">
                    <Badge variant="outline" className="font-mono">
                      {currency}
                    </Badge>
                    <p className="text-lg font-semibold">
                      {formatCurrency(amount, currency)}
                    </p>
                  </div>
                ))}
              </div>
            ) : (
              <div>
                <p className="text-sm text-muted-foreground mb-1">Total Mensual</p>
                <div className="text-3xl font-bold">
                  {formatCurrency(costsByCurrency[primaryCurrency] || 0, primaryCurrency)}
                </div>
              </div>
            )}
          </div>

          {/* Stats */}
          <div className="pt-4 border-t">
            <div className="flex justify-between items-center">
              <p className="text-sm text-muted-foreground">Costos Configurados</p>
              <p className="text-lg font-semibold">{totalCosts}</p>
            </div>
          </div>
        </div>
      </CardContent>
    </Card>
  )
}

