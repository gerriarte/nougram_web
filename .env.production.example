# ============================================
# Variables de Entorno para PRODUCCIÓN (Docker Compose)
# ============================================
# Uso: cp .env.production.example .env.production
#      Editar .env.production con valores reales
#      docker compose -f docker-compose.prod.yml --env-file .env.production up -d
#
# ⚠️ NO commitear .env.production al repositorio
# ============================================

# ============================================
# POSTGRES (OBLIGATORIO)
# ============================================
POSTGRES_USER=postgres
POSTGRES_PASSWORD=cambiar-password-seguro
POSTGRES_DB=nougram_db

# ============================================
# DATABASE_URL (OBLIGATORIO)
# Usar host "postgres" (nombre del servicio en compose)
# ============================================
DATABASE_URL=postgresql+asyncpg://postgres:cambiar-password-seguro@postgres:5432/nougram_db

# ============================================
# SEGURIDAD JWT (OBLIGATORIO)
# Generar con: python -c "import secrets; print(secrets.token_urlsafe(32))"
# ============================================
SECRET_KEY=generar-clave-secreta-de-32-caracteres-minimo

# ============================================
# CORS Y FRONTEND (OBLIGATORIO)
# ============================================
CORS_ORIGINS=https://tudominio.com,https://www.tudominio.com
FRONTEND_URL=https://tudominio.com

# ============================================
# FRONTEND - URL API (OBLIGATORIO)
# Debe apuntar al mismo dominio (nginx hace proxy de /api)
# ============================================
NEXT_PUBLIC_API_URL=https://tudominio.com/api/v1

# ============================================
# PUERTOS HTTP/HTTPS (Opcional)
# ============================================
HTTP_PORT=80
HTTPS_PORT=443

# ============================================
# SSL (Solo si usas docker-compose.prod.ssl.yml)
# ============================================
SSL_DOMAIN=app.tudominio.com
SSL_EMAIL=admin@tudominio.com

# ============================================
# GOOGLE (Obligatorio si usas OAuth/Sheets)
# ============================================
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_SERVICE_ACCOUNT_PATH=
GOOGLE_SHEETS_ID=

# ============================================
# IA (Opcional)
# ============================================
OPENAI_API_KEY=
GOOGLE_AI_API_KEY=

# ============================================
# EMAIL SMTP (Opcional)
# ============================================
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_FROM_NAME=Nougram

# ============================================
# STRIPE (Opcional)
# ============================================
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_IDS={}

# ============================================
# EXCHANGE RATES (Opcional)
# ============================================
EXCHANGE_RATE_API_KEY=

# ============================================
# CELERY (Opcional - usa Redis por defecto)
# ============================================
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

# ============================================
# PUBLIC QUOTE URL (Opcional)
# ============================================
PUBLIC_QUOTE_BASE_URL=
