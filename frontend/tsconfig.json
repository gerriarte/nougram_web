{
  "compilerOptions": {
    "target": "ES2020",
    "lib": [
      "dom",
      "dom.iterable",
      "esnext"
    ],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "forceConsistentCasingInFileNames": false,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/*": [
        "./src/*"
      ],
      "@/components/ui/Badge": [
        "./src/components/ui/badge"
      ],
      "@/components/ui/Button": [
        "./src/components/ui/button"
      ],
      "@/components/ui/Card": [
        "./src/components/ui/card"
      ],
      "@/components/ui/Dialog": [
        "./src/components/ui/dialog"
      ],
      "@/components/ui/Input": [
        "./src/components/ui/input"
      ],
      "@/components/ui/Label": [
        "./src/components/ui/label"
      ],
      "@/components/ui/Tabs": [
        "./src/components/ui/tabs"
      ]
    }
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "e2e/**/*",
    "src/legacy_routes/**/*",
    "src/scripts/**/*",
    "playwright.config.ts",
    "vitest.config.ts",
    "vitest.setup.ts",
    "src/backup/**/*"
  ]
}
