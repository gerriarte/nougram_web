```typescript
"use client";

import { useState, useEffect } from 'react';
import { useRouter } from 'next/navigation';
import { motion } from 'framer-motion';
import { OnboardingStepWrapper } from '@/components/onboarding/OnboardingStepWrapper';
import { IdentityStep } from '@/components/onboarding/IdentityStep';
import { BusinessProfileStep } from '@/components/onboarding/BusinessProfileStep';
import { TeamConfigurationStep } from '@/components/onboarding/TeamConfigurationStep';
import { OperationalExpensesStep } from '@/components/onboarding/OperationalExpensesStep';
import { SummaryStep } from '@/components/onboarding/SummaryStep';
import { Button } from '@/components/ui/button';
import { ChevronRight, ArrowLeft } from 'lucide-react';
import { useGetCurrentUser } from '@/lib/queries';
import { useOnboardingStore } from '@/stores/onboarding-store';

export default function OnboardingPage() {
  const router = useRouter();
  const [currentStep, setCurrentStep] = useState(1);
  const totalSteps = 5;
  const { data: currentUser, isLoading: userLoading } = useGetCurrentUser();

  // Validar que solo owners puedan acceder
  useEffect(() => {
    if (!userLoading && currentUser) {
      if (currentUser.role !== 'owner') {
        router.push('/dashboard');
      }
    }
  }, [currentUser, userLoading, router]);

  const handleNext = () => {
    // Validaciones por paso
    if (currentStep === 1) {
      const { organizationName, country, currency } = useOnboardingStore.getState();
      if (!organizationName || !country || !currency) {
        alert('Por favor completa todos los campos');
        return;
      }
    }
    if (currentStep === 2) {
      const { profileType } = useOnboardingStore.getState();
      if (!profileType) {
        alert('Por favor selecciona un perfil');
        return;
      }
    }
    if (currentStep === 3) {
      const { teamMembers } = useOnboardingStore.getState();
      if (teamMembers.length === 0) {
        alert('Por favor agrega al menos un miembro del equipo');
        return;
      }
    }

    if (currentStep < totalSteps) {
      setCurrentStep(currentStep + 1);
    }
  };

  const handleBack = () => {
    if (currentStep > 1) {
      setCurrentStep(currentStep - 1);
    }
  };

  const handleFinish = async () => {
    // Guardar toda la configuración
    // Esto se manejará en SummaryStep
    router.push('/dashboard');
  };

  if (userLoading) {
    return (
      <div className="min-h-screen bg-[#F5F5F7] flex items-center justify-center">
        <div className="text-[#86868b]">Cargando...</div>
      </div>
    );
  }

  return (
    <div className="min-h-screen bg-[#F5F5F7]">
      {/* Progress bar */}
      <div className="w-full h-1 bg-white/50">
        <motion.div
          className="h-full bg-primary-500"
          initial={{ width: 0 }}
          animate={{ width: `${(currentStep / totalSteps) * 100}%` }}
          transition={{ type: "spring", stiffness: 300, damping: 30 }}
        />
      </div>

      {/* Main content */}
      <div className="container mx-auto px-4 py-12 max-w-4xl">
        {/* Step content */}
        <OnboardingStepWrapper step={1} currentStep={currentStep}>
          <IdentityStep />
        </OnboardingStepWrapper>

        <OnboardingStepWrapper step={2} currentStep={currentStep}>
          <BusinessProfileStep />
        </OnboardingStepWrapper>

        <OnboardingStepWrapper step={3} currentStep={currentStep}>
          <TeamConfigurationStep />
        </OnboardingStepWrapper>

        <OnboardingStepWrapper step={4} currentStep={currentStep}>
          <OperationalExpensesStep />
        </OnboardingStepWrapper>

        <OnboardingStepWrapper step={5} currentStep={currentStep}>
          <SummaryStep onFinish={handleFinish} />
        </OnboardingStepWrapper>

        {/* Navigation */}
        {currentStep < totalSteps && (
          <motion.div
            initial={{ opacity: 0 }}
            animate={{ opacity: 1 }}
            className="flex justify-between mt-8"
          >
            <Button
              variant="outline"
              onClick={handleBack}
              disabled={currentStep === 1}
              className="bg-white/70 backdrop-blur-md border-white/80"
            >
              <ArrowLeft className="w-4 h-4 mr-2" strokeWidth={1.5} />
              Atrás
            </Button>
            <Button
              onClick={handleNext}
              className="bg-primary-500 hover:bg-primary-600 text-white"
            >
              Continuar
              <ChevronRight className="w-4 h-4 ml-2" strokeWidth={1.5} />
            </Button>
          </motion.div>
        )}
      </div>
    </div>
  );
}
