"use client";

import { motion } from 'framer-motion';
import { Users, Plus, Trash2, Calculator } from 'lucide-react';
import { useOnboardingStore, TeamMember } from '@/stores/onboarding-store';
import { Button } from '@/components/ui/button';
import { Input } from '@/components/ui/input';
import { Select } from '@/components/ui/select';
import { useState } from 'react';
import { formatCurrency } from '@/lib/currency';

export function TeamConfigurationStep() {
  const { teamMembers, addTeamMember, removeTeamMember, currency } = useOnboardingStore();
  const [isFormOpen, setIsFormOpen] = useState(false);
  const [formData, setFormData] = useState<Partial<TeamMember>>({
    name: '',
    role: '',
    salary: 0,
    billableHours: 40,
    currency: currency || 'USD',
  });

  const handleAddMember = () => {
    if (formData.name && formData.role && formData.salary) {
      addTeamMember(formData as TeamMember);
      setFormData({
        name: '',
        role: '',
        salary: 0,
        billableHours: 40,
        currency: currency || 'USD',
      });
      setIsFormOpen(false);
    }
  };

  const totalCost = teamMembers.reduce((sum, member) => {
    return sum + (member.salary || 0);
  }, 0);

  return (
    <div className="space-y-6">
      {/* Título */}
      <motion.div
        initial={{ opacity: 0, y: -10 }}
        animate={{ opacity: 1, y: 0 }}
      >
        <h2 className="text-3xl font-bold tracking-tight text-[#1d1d1f] mb-2">
          Configura tu equipo
        </h2>
        <p className="text-[#86868b] text-sm">
          Agrega miembros y configura salarios, roles y factor de prestaciones
        </p>
      </motion.div>

      {/* Resumen de costo total */}
      {teamMembers.length > 0 && (
        <motion.div
          initial={{ opacity: 0 }}
          animate={{ opacity: 1 }}
          className="bg-white/70 backdrop-blur-md rounded-2xl p-4 border border-white/80"
        >
          <div className="flex items-center justify-between">
            <div className="flex items-center gap-2">
              <Calculator className="w-5 h-5 text-[#86868b]" strokeWidth={1.5} />
              <span className="text-sm text-[#86868b]">Costo total mensual:</span>
            </div>
            <span className="text-xl font-bold text-[#1d1d1f]">
              {formatCurrency(totalCost, currency || 'USD')}
            </span>
          </div>
        </motion.div>
      )}

      {/* Botón agregar miembro */}
      {!isFormOpen && (
        <Button
          onClick={() => setIsFormOpen(true)}
          className="bg-white/70 backdrop-blur-md border border-white/80 text-[#1d1d1f] hover:bg-white/90"
        >
          <Plus className="w-4 h-4 mr-2" strokeWidth={1.5} />
          Agregar miembro
        </Button>
      )}

      {/* Formulario */}
      {isFormOpen && (
        <motion.div
          initial={{ opacity: 0, height: 0 }}
          animate={{ opacity: 1, height: 'auto' }}
          className="bg-white/70 backdrop-blur-md rounded-2xl p-6 border border-white/80"
        >
          {/* Formulario de agregar miembro */}
          <div className="grid grid-cols-2 gap-4">
            <Input
              placeholder="Nombre"
              value={formData.name}
              onChange={(e) => setFormData({ ...formData, name: e.target.value })}
            />
            <Input
              placeholder="Rol"
              value={formData.role}
              onChange={(e) => setFormData({ ...formData, role: e.target.value })}
            />
            <Input
              type="number"
              placeholder="Salario mensual"
              value={formData.salary || ''}
              onChange={(e) => setFormData({ ...formData, salary: parseFloat(e.target.value) || 0 })}
            />
            <Input
              type="number"
              placeholder="Horas facturables/mes"
              value={formData.billableHours || ''}
              onChange={(e) => setFormData({ ...formData, billableHours: parseFloat(e.target.value) || 40 })}
            />
          </div>
          <div className="flex gap-2 mt-4">
            <Button onClick={handleAddMember} className="flex-1">
              Agregar
            </Button>
            <Button variant="outline" onClick={() => setIsFormOpen(false)}>
              Cancelar
            </Button>
          </div>
        </motion.div>
      )}

      {/* Tabla de miembros */}
      {teamMembers.length > 0 && (
        <motion.div
          initial={{ opacity: 0 }}
          animate={{ opacity: 1 }}
          className="bg-white/70 backdrop-blur-md rounded-2xl p-6 border border-white/80"
        >
          <div className="space-y-3">
            {teamMembers.map((member, index) => (
              <div
                key={index}
                className="flex items-center justify-between p-3 bg-white/50 rounded-xl"
              >
                <div>
                  <p className="font-medium text-[#1d1d1f]">{member.name}</p>
                  <p className="text-sm text-[#86868b]">{member.role}</p>
                </div>
                <div className="text-right">
                  <p className="font-medium text-[#1d1d1f]">
                    {formatCurrency(member.salary, member.currency || currency || 'USD')}
                  </p>
                  <p className="text-xs text-[#86868b]">{member.billableHours}h/mes</p>
                </div>
                <Button
                  variant="ghost"
                  size="sm"
                  onClick={() => removeTeamMember(index)}
                >
                  <Trash2 className="w-4 h-4" strokeWidth={1.5} />
                </Button>
              </div>
            ))}
          </div>
        </motion.div>
      )}
    </div>
  );
}
