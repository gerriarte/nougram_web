### 3. ✅ Componente: OnboardingStepWrapper

**Estado:** ❌ Pendiente

**Archivo:** `frontend/src/components/onboarding/OnboardingStepWrapper.tsx` (nuevo)

**Propósito:** Wrapper con transiciones Framer Motion y estilo Apple

**Implementación:**

```typescript
"use client";

import { motion, AnimatePresence } from 'framer-motion';
import { ReactNode } from 'react';

interface OnboardingStepWrapperProps {
  children: ReactNode;
  step: number;
  currentStep: number;
}

export function OnboardingStepWrapper({ 
  children, 
  step, 
  currentStep 
}: OnboardingStepWrapperProps) {
  return (
    <AnimatePresence mode="wait">
      {step === currentStep && (
        <motion.div
          key={step}
          initial={{ opacity: 0, y: 20 }}
          animate={{ opacity: 1, y: 0 }}
          exit={{ opacity: 0, y: -20 }}
          transition={{
            type: "spring",
            stiffness: 300,
            damping: 30
          }}
          className="w-full"
        >
          {children}
        </motion.div>
      )}
    </AnimatePresence>
  );
}
```

